# ═══════════════════════════════════════
#  TGArb JS — Environment
# ═══════════════════════════════════════

# Telegram API (my.telegram.org)
TG_API_ID=12345678
TG_API_HASH=abcdef1234567890abcdef1234567890

# Telegram Bot (@BotFather)
BOT_TOKEN=1234567890:AABBCCDDEEFFaabbccddeeff

# База данных (не менять если используешь Docker)
DATABASE_URL=postgresql://tgarb:secret@db:5432/tgarb

# MongoDB для Agenda (не менять если используешь Docker)
MONGODB_URL=mongodb://mongo:27017/tgarb_jobs

# Redis (не менять если используешь Docker)
REDIS_URL=redis://redis:6379

# Трекер — домен сервера
TRACKER_BASE_URL=http://localhost:3000/r

# ── CPA сети (опционально) ──────────────────────────────
# Admitad: https://publishers.admitad.com → API
ADMITAD_PUBLISHER_ID=
ADMITAD_TOKEN=

# LeadGid: https://leadgid.com → Настройки → API
LEADGID_API_KEY=

# Alfaleads: https://alfaleads.com → Профиль → API
ALFALEADS_API_KEY=
